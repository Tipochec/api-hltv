
# ── САМОЕ ВАЖНОЕ: секреты ─────────────────────────────────────────
.env                    # API-ключи, пароли — НИКОГДА не публиковать!
*.key
*.pem
secrets.json


# ── Виртуальное окружение ─────────────────────────────────────────
.venv/
venv/
env/
ENV/


# ── Python кэш ────────────────────────────────────────────────────
__pycache__/
*.py[cod]               # .pyc, .pyo, .pyd
*.pyo
.Python


# ── Тесты и покрытие ──────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml


# ── Линтеры и тайп-чекеры ─────────────────────────────────────────
.mypy_cache/
.ruff_cache/


# ── Сборка ────────────────────────────────────────────────────────
build/
dist/
*.egg-info/
*.spec               # PyInstaller (если не нужен в репо)


# ── IDE ───────────────────────────────────────────────────────────
.idea/               # PyCharm
.vscode/             # VS Code (можно убрать если хочешь шарить настройки)
*.swp
*.swo


# ── OS ────────────────────────────────────────────────────────────
.DS_Store            # macOS
Thumbs.db            # Windows
desktop.ini


# ── Логи ──────────────────────────────────────────────────────────
*.log
logs/


